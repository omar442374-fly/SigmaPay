    class PaymentRepositoryImpl {
        - dataAccessLayer: IDataAccessLayer
    }
    
    class GroupSavingsRepositoryImpl {
        - dataAccessLayer: IDataAccessLayer
    }
    
    class NotificationRepositoryImpl {
        - dataAccessLayer: IDataAccessLayer
    }
    
    class DataAccessLayerImpl {
