    class BankAPI <<external>> {
        + transfer(from: String, to: String, amount: double): Response
        + getBalance(account: String): double
    }
    
    class VodafoneAPI <<external>> {
        + sendMoney(from: String, to: String, amount: double): Response
        + checkBalance(wallet: String): double
    }
    
    class EmailService <<external>> {
        + sendEmail(to: String, subject: String, body: String): void
    }
    
    class SMSService <<external>> {
        + sendSMS(to: String, message: String): void
    }
}

