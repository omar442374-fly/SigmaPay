' ================================
' DATA ACCESS LAYER
' ================================

package "Data Access Layer" as DataLayer {
    
    ' Data Access Interface
    interface IDataAccessLayer {
        + connect(): Connection
        + disconnect(): void
        + executeQuery(query: String): ResultSet
        + executeUpdate(query: String): int
        + beginTransaction(): void
        + commitTransaction(): void
        + rollbackTransaction(): void
    }
    
    ' Repository Interfaces (What Services see)
    interface IRepository<T> {
        + save(entity: T): String
        + findById(id: String): T
        + update(entity: T): void
        + delete(id: String): void
        + findAll(): List<T>
    }
    
    interface IAccountsRepository {
        + save(account: IAccount): String
        + findById(accountId: String): IAccount
        + findByUserId(userId: String): List<IAccount>
        + update(account: IAccount): void
        + delete(accountId: String): void
    }
    
    interface IUserRepository {
        + save(user: IUserAccount): String
        + findById(userId: String): IUserAccount
        + findByUsername(username: String): IUserAccount
        + findByEmail(email: String): IUserAccount
        + update(user: IUserAccount): void
        + delete(userId: String): void
    }
    
    interface ITransactionRepository {
        + save(transaction: ITransaction): String
        + findById(transactionId: String): ITransaction
        + findByAccountId(accountId: String): List<ITransaction>
        + findByDateRange(accountId: String, start: DateTime, end: DateTime): List<ITransaction>
        + findByFilter(filter: ReportFilter): List<ITransaction>
        + update(transaction: ITransaction): void
        + delete(transactionId: String): void
    }
    
    interface IBudgetRepository {
        + save(budget: IBudgetPlan): String
        + findById(budgetId: String): IBudgetPlan
        + findByUserId(userId: String): List<IBudgetPlan>
        + findActive(userId: String): IBudgetPlan
        + update(budget: IBudgetPlan): void
        + delete(budgetId: String): void
    }
    
    interface IGoalRepository {
        + save(goal: IFinancialGoal): String
        + findById(goalId: String): IFinancialGoal
        + findByUserId(userId: String): List<IFinancialGoal>
        + findActiveGoals(userId: String): List<IFinancialGoal>
        + update(goal: IFinancialGoal): void
        + delete(goalId: String): void
    }
    
    interface IPaymentRepository {
        + save(payment: IPayment): String
        + findById(paymentId: String): IPayment
        + findByAccountId(accountId: String): List<IPayment>
        + findPending(): List<IPayment>
        + update(payment: IPayment): void
        + delete(paymentId: String): void
    }
    
    interface IGroupSavingsRepository {
        + save(group: IGroupSavings): String
        + findById(groupId: String): IGroupSavings
        + findByMember(userId: String): List<IGroupSavings>
        + update(group: IGroupSavings): void
        + delete(groupId: String): void
    }
    
    interface INotificationRepository {
        + save(notification: INotification): String
        + findById(notificationId: String): INotification
        + findByUserId(userId: String): List<INotification>
        + findUnread(userId: String): List<INotification>
        + update(notification: INotification): void
        + delete(notificationId: String): void
    }
    
    ' Concrete Repository Implementations (depend on IDataAccessLayer)
    class AccountsRepositoryImpl {
        - dataAccessLayer: IDataAccessLayer
    }
    
    class UserRepositoryImpl {
        - dataAccessLayer: IDataAccessLayer
    }
    
    class TransactionRepositoryImpl {
        - dataAccessLayer: IDataAccessLayer
    }
    
    class BudgetRepositoryImpl {
        - dataAccessLayer: IDataAccessLayer
    }
    
    class GoalRepositoryImpl {
        - dataAccessLayer: IDataAccessLayer
    }
    
    class PaymentRepositoryImpl {
        - dataAccessLayer: IDataAccessLayer
    }
    
    class GroupSavingsRepositoryImpl {
        - dataAccessLayer: IDataAccessLayer
    }
    
    class NotificationRepositoryImpl {
        - dataAccessLayer: IDataAccessLayer
    }
    
    ' Repository implementations implement their interfaces
    IRepository <|.. IAccountsRepository
    IRepository <|.. IUserRepository
    IRepository <|.. ITransactionRepository
    IRepository <|.. IBudgetRepository
    IRepository <|.. IGoalRepository
    IRepository <|.. IPaymentRepository
    IRepository <|.. IGroupSavingsRepository
    IRepository <|.. INotificationRepository
    
    IAccountsRepository <|.. AccountsRepositoryImpl
    IUserRepository <|.. UserRepositoryImpl
    ITransactionRepository <|.. TransactionRepositoryImpl
    IBudgetRepository <|.. BudgetRepositoryImpl
    IGoalRepository <|.. GoalRepositoryImpl
    IPaymentRepository <|.. PaymentRepositoryImpl
    IGroupSavingsRepository <|.. GroupSavingsRepositoryImpl
    INotificationRepository <|.. NotificationRepositoryImpl
    
    ' Repositories depend on IDataAccessLayer (interface, not concrete)
    AccountsRepositoryImpl --> IDataAccessLayer
    UserRepositoryImpl --> IDataAccessLayer
    TransactionRepositoryImpl --> IDataAccessLayer
    BudgetRepositoryImpl --> IDataAccessLayer
    GoalRepositoryImpl --> IDataAccessLayer
    PaymentRepositoryImpl --> IDataAccessLayer
    GroupSavingsRepositoryImpl --> IDataAccessLayer
    NotificationRepositoryImpl --> IDataAccessLayer
    
    ' Database Connection Pool (Singleton)
    class DatabaseConnectionPool {
        - {static} instance: DatabaseConnectionPool
        - connections: Queue<Connection>
        - maxConnections: int
        
        - DatabaseConnectionPool()
        + {static} getInstance(): DatabaseConnectionPool
        + getConnection(): Connection
        + releaseConnection(conn: Connection): void
    }
    
    ' Concrete implementation of IDataAccessLayer
    class DataAccessLayerImpl {
        - connectionPool: DatabaseConnectionPool
    }
    
    IDataAccessLayer <|.. DataAccessLayerImpl
    DataAccessLayerImpl --> DatabaseConnectionPool
}

' ================================
' CROSS-CUTTING CONCERNS
' ================================

package "Cross-Cutting Concerns" as CrossCutting {
    
    class SessionManager {
        - activeSessions: Map<String, Session>
    }
    
    class PasswordHasher {
        + hash(password: String, salt: String): String
        + verify(password: String, hash: String): boolean
        + generateSalt(): String
    }
    
    class PasswordPolicy {
        - minLength: int
        - requireUppercase: boolean
        - requireLowercase: boolean
        - requireDigits: boolean
        - requireSpecialChars: boolean
    }
    
    class ValidationRequest {
        - data: Map<String, Object>
    }
    
    class ValidationResult {
        - valid: boolean
        - errors: List<String>
    }
    
    class Event {
        - eventType: String
        - data: Object
        - timestamp: DateTime
    }
    
    class NotificationEvent {
        - userId: String
        - message: String
        - priority: String
    }
    
    Event <|-- NotificationEvent
    
    PasswordManager --> PasswordHasher
    PasswordManager --> PasswordPolicy
    AuthProxy --> SessionManager
}

