' ==============================================
' SERVICE INTERFACES LAYER
' ==============================================
package "Service Interfaces" <<Rectangle>> {
    
    interface IAccountService {
        + createAccount(account: IAccount): String
        + getAccount(accountId: String): IAccount
        + updateAccount(account: IAccount): void
        + deleteAccount(accountId: String): void
        + getUserAccount(userId: String): IUserAccount
    }
    
    interface IBudgetService {
        + createBudget(plan: IBudgetPlan): String
        + updateBudget(plan: IBudgetPlan): void
        + deleteBudget(budgetId: String): void
        + getBudget(budgetId: String): IBudgetPlan
        + recordExpense(userId: String, amount: double, category: String): boolean
        + analyzeSpending(budgetId: String): SpendingAnalysis
    }
    
    interface IGoalService {
        + createGoal(goal: IFinancialGoal): String
        + updateGoal(goal: IFinancialGoal): void
        + trackProgress(goalId: String): IGoalProgress
        + contributeToGoal(goalId: String, amount: double): void
    }
    
    interface IGroupSavingsService {
        + createGroup(group: IGroupSavings): String
