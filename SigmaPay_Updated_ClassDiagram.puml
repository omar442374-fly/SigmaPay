' ==============================================
' DOMAIN ENTITIES
' ==============================================
package "Domain Entities (Refactored)" <<Rectangle>> {
    
    ' Refactored UserAccount (Extract Class applied)
    class UserAccount {
        - userId: String
        - credentials: Credentials
        - profile: UserProfile
        - securitySettings: SecuritySettings
    }
    
    class Credentials {
        - username: String
        - passwordHash: String
    }
    
    class UserProfile {
        - email: String
        - phone: String
        - address: Address
    }
    
    class SecuritySettings {
        - twoFactorEnabled: boolean
        - accountStatus: String
    }
    
    ' Money Value Object (Replace Primitive)
    class Money {
        - amount: BigDecimal
        - currency: Currency
    }
    
    class Currency {
        - code: String
        - symbol: String
        - exchangeRate: double
    }
    
    class Account {
        - accountId: String
        - balance: Money
    }
    
    class Transaction {
        - transactionId: String
        - amount: Money
        - merchantType: MerchantType
    }
    
    class BudgetPlan {
        - budgetId: String
        - totalAmount: Money
        - rootCategory: BudgetCategoryGroup
    }
    
    class FinancialGoal {
        - goalId: String
        - targetAmount: Money
        - currentAmount: Money
        - state: IGoalState
    }
    
    abstract class Payment {
        # paymentId: String
        # amount: Money
        # state: IPaymentState
        # strategy: IPaymentStrategy
    }
    
    class CardPayment
    class WalletPayment
    class BankPayment
    class GroupContributionPayment
    
    class GroupSavings {
        - groupId: String
        - targetAmount: Money
    }
    
    class Report {
        - reportId: String
        - sections: List<ReportSection>
    }
    
    class Notification {
        - notificationId: String
        - message: String
    }
    
    ' Entity implementations
    IUserAccount <|.. UserAccount
    IAccount <|.. Account
    IMoney <|.. Money
    ITransaction <|.. Transaction
    IBudgetPlan <|.. BudgetPlan
    IFinancialGoal <|.. FinancialGoal
    IPayment <|.. Payment
    IGroupSavings <|.. GroupSavings
    IReport <|.. Report
    INotification <|.. Notification
    
    Payment <|-- CardPayment
    Payment <|-- WalletPayment
    Payment <|-- BankPayment
    Payment <|-- GroupContributionPayment
    
    UserAccount --> Credentials
    UserAccount --> UserProfile
    UserAccount --> SecuritySettings
    Money --> Currency
    BudgetPlan --> BudgetCategoryGroup
    FinancialGoal --> IGoalState
    Payment --> IPaymentState
    Payment --> IPaymentStrategy
}

