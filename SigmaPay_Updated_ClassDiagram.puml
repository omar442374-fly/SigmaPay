    }
    
    IAccountsRepository <|.. AccountsRepositoryImpl
    IUserRepository <|.. UserRepositoryImpl
    ITransactionRepository <|.. TransactionRepositoryImpl
    IBudgetRepository <|.. BudgetRepositoryImpl
    IGoalRepository <|.. GoalRepositoryImpl
    IPaymentRepository <|.. PaymentRepositoryImpl
    IGroupSavingsRepository <|.. GroupSavingsRepositoryImpl
    INotificationRepository <|.. NotificationRepositoryImpl
    IDataAccessLayer <|.. DataAccessLayerImpl
    
    AccountsRepositoryImpl --> IDataAccessLayer
