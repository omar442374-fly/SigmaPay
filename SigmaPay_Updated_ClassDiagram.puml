@startuml SigmaPay_Updated_Class_Diagram

' ============================================================================
' SigmaPay - Updated Class Diagram with Design Patterns
' ============================================================================
' This diagram incorporates 12 GoF design patterns and refactoring techniques
' Based on: Deliverable1_Final_Report.txt and Arch.drawio architecture
' Layers: Presentation (Controller), Business Domain, Data Access
' ============================================================================

skinparam packageStyle rectangle
skinparam linetype ortho
skinparam classAttributeIconSize 0

' ============================================================================
' PRESENTATION LAYER - Controllers (Facade Pattern)
' ============================================================================

package "Presentation Layer (Controller)" as PresentationLayer {
    
    ' Facade Pattern - Single entry point
    class SigmaPayFacade {
        - accountService: AccountService
        - budgetService: BudgetCreationService
        - budgetAnalytics: BudgetAnalyticsService
        - goalService: GoalService
        - groupSavingsService: GroupSavingsService
        - paymentsService: PaymentsServiceBL
        - reportingService: ReportingService
        - notificationService: NotificationsServiceBL
        
        + createAccount(data): Response
        + login(credentials): Response
        + createBudget(plan): Response
        + createGoal(goal): Response
        + processPayment(request): Response
        + generateReport(filter): Report
        + sendNotification(message): void
        + handle(request): Response
    }
    
    ' Original Controllers (now wrapped by Facade)
    class IControllerAuth {
        - authProxy: AuthProxy
        - validationChain: ValidationHandler
        + ctlCreateAccount()
        + ctlLogin()
        + ctlLogout()
    }
    
    class IControllerAccounts {
        - accountService: AccountService
        + ctlGetAccountDetails()
        + ctlUpdateAccount()
        + ctlDeleteAccount()
    }
    
    class IControllerBudget {
        - budgetCreationService: BudgetCreationService
        - budgetAnalytics: BudgetAnalyticsService
        + ctlCreateBudget()
        + ctlUpdateBudget()
        + ctlGetBudgetAnalytics()
    }
    
    class IControllerGoals {
        - goalService: GoalService
        + ctlCreateGoal()
        + ctlUpdateGoal()
        + ctlTrackProgress()
    }
    
    class IControllerPayments {
        - paymentService: PaymentsServiceBL
        - paymentCreator: PaymentCreator
        + ctlProcessPayment()
        + ctlSchedulePayment()
        + ctlGetPaymentHistory()
    }
    
    class IControllerReports {
        - reportingService: ReportingService
        - reportBuilder: ReportBuilder
        + ctlGenerateReport()
        + ctlExportToPDF()
    }
    
    class IControllerNotifications {
        - notificationManager: NotificationManager
        + ctlSendNotification()
        + ctlGetNotifications()
    }
    
    class IControllerGroupSavings {
        - groupSavingsService: GroupSavingsService
        + ctlCreateGroup()
        + ctlJoinGroup()
        + ctlContribute()
    }
    
    ' Facade uses all controllers
    SigmaPayFacade --> IControllerAuth
    SigmaPayFacade --> IControllerAccounts
    SigmaPayFacade --> IControllerBudget
    SigmaPayFacade --> IControllerGoals
    SigmaPayFacade --> IControllerPayments
    SigmaPayFacade --> IControllerReports
    SigmaPayFacade --> IControllerNotifications
    SigmaPayFacade --> IControllerGroupSavings
}

' ============================================================================
' BUSINESS/DOMAIN LAYER
' ============================================================================

package "Business/Domain Layer" as BusinessLayer {
    
    ' ========================================================================
    ' CREATIONAL PATTERNS
    ' ========================================================================
    
    ' Factory Method Pattern - Payment Creation
    abstract class PaymentCreator {
        + {abstract} createPayment(methodType: String): Payment
        + processPayment(methodType: String): Payment
    }
    
    class ConcretePaymentCreator {
        + createPayment(methodType: String): Payment
    }
    
    PaymentCreator <|-- ConcretePaymentCreator
    
    ' Builder Pattern - Report Construction
    class ReportBuilder {
        - report: Report
        + reset(): void
        + buildHeader(title: String): ReportBuilder
        + buildSection(name: String, data: Object): ReportBuilder
        + buildChart(type: String, data: Object): ReportBuilder
        + buildTotals(totals: Map): ReportBuilder
        + buildAnalytics(analytics: Object): ReportBuilder
        + buildFooter(): ReportBuilder
        + getReport(): Report
    }
    
    ' Singleton Pattern - Notification Manager
    class NotificationManager {
        - {static} instance: NotificationManager
        - observers: List<NotificationObserver>
        - scheduler: Scheduler
        
        - NotificationManager()
        + {static} getInstance(): NotificationManager
        + subscribe(observer: NotificationObserver): void
        + unsubscribe(observer: NotificationObserver): void
        + notify(event: NotificationEvent): void
        + scheduleNotification(notification: Notification, time: DateTime): void
    }
    
    ' Singleton Pattern - Scheduler
    class Scheduler {
        - {static} instance: Scheduler
        - scheduledTasks: Map<String, Task>
        
        - Scheduler()
        + {static} getInstance(): Scheduler
        + scheduleTask(task: Task, time: DateTime): String
        + cancelTask(taskId: String): void
        + rescheduleTask(taskId: String, newTime: DateTime): void
    }
    
    ' ========================================================================
    ' STRUCTURAL PATTERNS
    ' ========================================================================
    
    ' Adapter Pattern - Payment Gateway Integration
    interface PaymentGatewayAdapter {
        + processTransaction(transaction: Transaction): Response
        + refund(transactionId: String): Response
        + getStatus(transactionId: String): String
    }
    
    class FawryAdapter {
        - fawryAPI: FawryAPI
        + processTransaction(transaction: Transaction): Response
        + refund(transactionId: String): Response
        + getStatus(transactionId: String): String
    }
    
    class BankAPIAdapter {
        - bankAPI: BankAPI
        + processTransaction(transaction: Transaction): Response
        + refund(transactionId: String): Response
        + getStatus(transactionId: String): String
    }
    
    class VodafoneCashAdapter {
        - vodafoneAPI: VodafoneAPI
        + processTransaction(transaction: Transaction): Response
        + refund(transactionId: String): Response
        + getStatus(transactionId: String): String
    }
    
    PaymentGatewayAdapter <|.. FawryAdapter
    PaymentGatewayAdapter <|.. BankAPIAdapter
    PaymentGatewayAdapter <|.. VodafoneCashAdapter
    
    ' Proxy Pattern - Authentication & Authorization
    class AuthProxy {
        - realAuthService: AuthenticationService
        - sessionManager: SessionManager
        
        + authenticate(credentials: Credentials): boolean
        + authorize(user: User, resource: String): boolean
        + verify2FA(user: User, code: String): boolean
        + validateSession(sessionId: String): boolean
        + resetPassword(user: User, newPassword: String): boolean
    }
    
    class AuthenticationService {
        + authenticate(credentials: Credentials): boolean
        + verifyIdentity(user: User): boolean
        + enable2FA(user: User): void
    }
    
    AuthProxy --> AuthenticationService
    
    ' Composite Pattern - Budget Categories
    abstract class BudgetCategoryComponent {
        # name: String
        # amount: Money
        
        + {abstract} getAmount(): Money
        + {abstract} add(component: BudgetCategoryComponent): void
        + {abstract} remove(component: BudgetCategoryComponent): void
        + {abstract} getChild(index: int): BudgetCategoryComponent
        + {abstract} display(indent: int): void
    }
    
    class BudgetCategoryLeaf {
        + getAmount(): Money
        + add(component: BudgetCategoryComponent): void
        + remove(component: BudgetCategoryComponent): void
        + getChild(index: int): BudgetCategoryComponent
        + display(indent: int): void
    }
    
    class BudgetCategoryGroup {
        - children: List<BudgetCategoryComponent>
        
        + getAmount(): Money
        + add(component: BudgetCategoryComponent): void
        + remove(component: BudgetCategoryComponent): void
        + getChild(index: int): BudgetCategoryComponent
        + display(indent: int): void
    }
    
    BudgetCategoryComponent <|-- BudgetCategoryLeaf
    BudgetCategoryComponent <|-- BudgetCategoryGroup
    BudgetCategoryGroup o-- BudgetCategoryComponent
    
    ' Flyweight Pattern - Shared Currency and Merchant Data
    class CurrencyFlyweight {
        - {static} currencies: Map<String, Currency>
        
        + {static} getCurrency(code: String): Currency
    }
    
    class Currency {
        - code: String
        - symbol: String
        - exchangeRate: double
        
        + Currency(code: String, symbol: String, exchangeRate: double)
    }
    
    class MerchantTypeFlyweight {
        - {static} merchantTypes: Map<String, MerchantType>
        
        + {static} getMerchantType(type: String): MerchantType
    }
    
    class MerchantType {
        - type: String
        - category: String
        
        + MerchantType(type: String, category: String)
    }
    
    CurrencyFlyweight --> Currency
    MerchantTypeFlyweight --> MerchantType
    
    ' ========================================================================
    ' BEHAVIORAL PATTERNS
    ' ========================================================================
    
    ' Strategy Pattern - Payment Processing Strategies
    interface PaymentStrategy {
        + execute(payment: Payment, adapter: PaymentGatewayAdapter): Response
        + validate(payment: Payment): boolean
        + calculateFees(amount: Money): Money
    }
    
    class CardStrategy {
        + execute(payment: Payment, adapter: PaymentGatewayAdapter): Response
        + validate(payment: Payment): boolean
        + calculateFees(amount: Money): Money
    }
    
    class WalletStrategy {
        + execute(payment: Payment, adapter: PaymentGatewayAdapter): Response
        + validate(payment: Payment): boolean
        + calculateFees(amount: Money): Money
    }
    
    class BankStrategy {
        + execute(payment: Payment, adapter: PaymentGatewayAdapter): Response
        + validate(payment: Payment): boolean
        + calculateFees(amount: Money): Money
    }
    
    class GroupContributionStrategy {
        + execute(payment: Payment, adapter: PaymentGatewayAdapter): Response
        + validate(payment: Payment): boolean
        + calculateFees(amount: Money): Money
    }
    
    PaymentStrategy <|.. CardStrategy
    PaymentStrategy <|.. WalletStrategy
    PaymentStrategy <|.. BankStrategy
    PaymentStrategy <|.. GroupContributionStrategy
    
    ' Observer Pattern - Event-driven Notifications
    interface NotificationSubject {
        + attach(observer: NotificationObserver): void
        + detach(observer: NotificationObserver): void
        + notifyObservers(event: Event): void
    }
    
    interface NotificationObserver {
        + update(event: Event): void
    }
    
    class BudgetObserver {
        + update(event: Event): void
    }
    
    class GoalObserver {
        + update(event: Event): void
    }
    
    class PaymentObserver {
        + update(event: Event): void
    }
    
    class ContributionObserver {
        + update(event: Event): void
    }
    
    NotificationObserver <|.. BudgetObserver
    NotificationObserver <|.. GoalObserver
    NotificationObserver <|.. PaymentObserver
    NotificationObserver <|.. ContributionObserver
    NotificationSubject --> NotificationObserver
    
    ' Chain of Responsibility - Validation Chain
    abstract class ValidationHandler {
        # nextHandler: ValidationHandler
        
        + setNext(handler: ValidationHandler): ValidationHandler
        + {abstract} validate(request: ValidationRequest): ValidationResult
        + handle(request: ValidationRequest): ValidationResult
    }
    
    class EmailFormatHandler {
        + validate(request: ValidationRequest): ValidationResult
    }
    
    class DuplicateUserHandler {
        + validate(request: ValidationRequest): ValidationResult
    }
    
    class PasswordStrengthHandler {
        + validate(request: ValidationRequest): ValidationResult
    }
    
    class IdentityVerificationHandler {
        + validate(request: ValidationRequest): ValidationResult
    }
    
    ValidationHandler <|-- EmailFormatHandler
    ValidationHandler <|-- DuplicateUserHandler
    ValidationHandler <|-- PasswordStrengthHandler
    ValidationHandler <|-- IdentityVerificationHandler
    
    ' State Pattern - Goal States
    interface GoalState {
        + start(goal: FinancialGoal): void
        + pause(goal: FinancialGoal): void
        + complete(goal: FinancialGoal): void
        + cancel(goal: FinancialGoal): void
    }
    
    class ActiveGoalState {
        + start(goal: FinancialGoal): void
        + pause(goal: FinancialGoal): void
        + complete(goal: FinancialGoal): void
        + cancel(goal: FinancialGoal): void
    }
    
    class PausedGoalState {
        + start(goal: FinancialGoal): void
        + pause(goal: FinancialGoal): void
        + complete(goal: FinancialGoal): void
        + cancel(goal: FinancialGoal): void
    }
    
    class CompletedGoalState {
        + start(goal: FinancialGoal): void
        + pause(goal: FinancialGoal): void
        + complete(goal: FinancialGoal): void
        + cancel(goal: FinancialGoal): void
    }
    
    class CancelledGoalState {
        + start(goal: FinancialGoal): void
        + pause(goal: FinancialGoal): void
        + complete(goal: FinancialGoal): void
        + cancel(goal: FinancialGoal): void
    }
    
    GoalState <|.. ActiveGoalState
    GoalState <|.. PausedGoalState
    GoalState <|.. CompletedGoalState
    GoalState <|.. CancelledGoalState
    
    ' State Pattern - Payment States
    interface PaymentState {
        + process(payment: Payment): void
        + complete(payment: Payment): void
        + fail(payment: Payment): void
        + refund(payment: Payment): void
    }
    
    class PendingPaymentState {
        + process(payment: Payment): void
        + complete(payment: Payment): void
        + fail(payment: Payment): void
        + refund(payment: Payment): void
    }
    
    class ProcessingPaymentState {
        + process(payment: Payment): void
        + complete(payment: Payment): void
        + fail(payment: Payment): void
        + refund(payment: Payment): void
    }
    
    class CompletedPaymentState {
        + process(payment: Payment): void
        + complete(payment: Payment): void
        + fail(payment: Payment): void
        + refund(payment: Payment): void
    }
    
    class FailedPaymentState {
        + process(payment: Payment): void
        + complete(payment: Payment): void
        + fail(payment: Payment): void
        + refund(payment: Payment): void
    }
    
    PaymentState <|.. PendingPaymentState
    PaymentState <|.. ProcessingPaymentState
    PaymentState <|.. CompletedPaymentState
    PaymentState <|.. FailedPaymentState
    
    ' Template Method - Report Generation
    abstract class ReportTemplate {
        + generate(): Report
        # {abstract} prepareHeader(): void
        # {abstract} collectData(): void
        # {abstract} formatContent(): void
        # {abstract} generateSummary(): void
        # {abstract} exportPDF(): void
    }
    
    class MonthlyReport {
        # prepareHeader(): void
        # collectData(): void
        # formatContent(): void
        # generateSummary(): void
        # exportPDF(): void
    }
    
    class IncomeStatementReport {
        # prepareHeader(): void
        # collectData(): void
        # formatContent(): void
        # generateSummary(): void
        # exportPDF(): void
    }
    
    class GroupSavingsReport {
        # prepareHeader(): void
        # collectData(): void
        # formatContent(): void
        # generateSummary(): void
        # exportPDF(): void
    }
    
    ReportTemplate <|-- MonthlyReport
    ReportTemplate <|-- IncomeStatementReport
    ReportTemplate <|-- GroupSavingsReport
    
    ' ========================================================================
    ' DOMAIN ENTITIES (Refactored)
    ' ========================================================================
    
    ' Refactored UserAccount (Extract Class applied)
    class UserAccount {
        - userId: String
        - credentials: Credentials
        - profile: UserProfile
        - securitySettings: SecuritySettings
        - createdAt: DateTime
        - lastLogin: DateTime
        
        + getUserId(): String
        + getCredentials(): Credentials
        + getProfile(): UserProfile
        + getSecuritySettings(): SecuritySettings
        + updateProfile(profile: UserProfile): void
        + updateCredentials(credentials: Credentials): void
    }
    
    class Credentials {
        - username: String
        - passwordHash: String
        
        + getUsername(): String
        + setPasswordHash(hash: String): void
        + verifyPassword(password: String): boolean
    }
    
    class UserProfile {
        - email: String
        - phone: String
        - address: Address
        - firstName: String
        - lastName: String
        
        + getEmail(): String
        + getPhone(): String
        + updateContact(email: String, phone: String): void
    }
    
    class SecuritySettings {
        - twoFactorEnabled: boolean
        - accountStatus: String
        - lastPasswordChange: DateTime
        - failedLoginAttempts: int
        
        + is2FAEnabled(): boolean
        + enable2FA(): void
        + disable2FA(): void
        + lockAccount(): void
        + unlockAccount(): void
    }
    
    class Address {
        - street: String
        - city: String
        - country: String
        - postalCode: String
    }
    
    UserAccount --> Credentials
    UserAccount --> UserProfile
    UserAccount --> SecuritySettings
    UserProfile --> Address
    
    ' Money Value Object (Replace Primitive)
    class Money {
        - amount: BigDecimal
        - currency: Currency
        
        + Money(amount: BigDecimal, currency: Currency)
        + add(other: Money): Money
        + subtract(other: Money): Money
        + multiply(factor: double): Money
        + compareTo(other: Money): int
        + getAmount(): BigDecimal
        + getCurrency(): Currency
    }
    
    Money --> Currency
    
    ' Account Entity
    class Account {
        - accountId: String
        - userId: String
        - accountType: String
        - balance: Money
        - accountNumber: String
        - createdAt: DateTime
        
        + getBalance(): Money
        + deposit(amount: Money): void
        + withdraw(amount: Money): void
        + transfer(toAccount: Account, amount: Money): void
    }
    
    Account --> Money
    
    ' Transaction Entity
    class Transaction {
        - transactionId: String
        - accountId: String
        - amount: Money
        - transactionType: String
        - merchantType: MerchantType
        - timestamp: DateTime
        - description: String
        
        + getAmount(): Money
        + getType(): String
        + getMerchantType(): MerchantType
    }
    
    Transaction --> Money
    Transaction --> MerchantType
    
    ' BudgetPlan Entity (with Composite)
    class BudgetPlan {
        - budgetId: String
        - userId: String
        - name: String
        - totalAmount: Money
        - startDate: DateTime
        - endDate: DateTime
        - rootCategory: BudgetCategoryGroup
        
        + getTotalAmount(): Money
        + addCategory(category: BudgetCategoryComponent): void
        + removeCategory(categoryName: String): void
        + getCategoryAmount(categoryName: String): Money
    }
    
    BudgetPlan --> Money
    BudgetPlan --> BudgetCategoryGroup
    
    ' FinancialGoal Entity (with State)
    class FinancialGoal {
        - goalId: String
        - userId: String
        - name: String
        - targetAmount: Money
        - currentAmount: Money
        - deadline: DateTime
        - state: GoalState
        
        + getTargetAmount(): Money
        + getCurrentAmount(): Money
        + contribute(amount: Money): void
        + setState(state: GoalState): void
        + start(): void
        + pause(): void
        + complete(): void
        + cancel(): void
    }
    
    FinancialGoal --> Money
    FinancialGoal --> GoalState
    
    ' Payment Entity (with State and Strategy)
    abstract class Payment {
        # paymentId: String
        # accountId: String
        # amount: Money
        # timestamp: DateTime
        # state: PaymentState
        # strategy: PaymentStrategy
        
        + {abstract} process(): Response
        + setState(state: PaymentState): void
        + setStrategy(strategy: PaymentStrategy): void
        + getAmount(): Money
    }
    
    class CardPayment {
        - cardNumber: String
        - cvv: String
        - expiryDate: String
        
        + process(): Response
    }
    
    class WalletPayment {
        - walletId: String
        
        + process(): Response
    }
    
    class BankPayment {
        - bankAccount: String
        - routingNumber: String
        
        + process(): Response
    }
    
    class GroupContributionPayment {
        - groupId: String
        - contributionId: String
        
        + process(): Response
    }
    
    Payment <|-- CardPayment
    Payment <|-- WalletPayment
    Payment <|-- BankPayment
    Payment <|-- GroupContributionPayment
    Payment --> Money
    Payment --> PaymentState
    Payment --> PaymentStrategy
    
    ' GroupSavings Entity
    class GroupSavings {
        - groupId: String
        - name: String
        - targetAmount: Money
        - currentAmount: Money
        - members: List<String>
        - createdAt: DateTime
        
        + addMember(userId: String): void
        + contribute(userId: String, amount: Money): void
        + getTargetAmount(): Money
        + getCurrentAmount(): Money
    }
    
    GroupSavings --> Money
    
    ' Report Entity (with Builder and Template)
    class Report {
        - reportId: String
        - title: String
        - generatedAt: DateTime
        - sections: List<ReportSection>
        - charts: List<Chart>
        - summary: String
        
        + addSection(section: ReportSection): void
        + addChart(chart: Chart): void
        + setSummary(summary: String): void
        + exportToPDF(): byte[]
    }
    
    class ReportSection {
        - name: String
        - content: String
        - data: Object
    }
    
    class Chart {
        - type: String
        - data: Object
        - config: ChartConfig
    }
    
    Report --> ReportSection
    Report --> Chart
    
    ' ReportFilter Parameter Object (Introduce Parameter Object)
    class ReportFilter {
        - startDate: DateTime
        - endDate: DateTime
        - category: String
        - type: String
        - minAmount: Money
        - maxAmount: Money
        
        + matches(transaction: Transaction): boolean
        + getStartDate(): DateTime
        + getEndDate(): DateTime
    }
    
    ReportFilter --> Money
    
    ' Notification Entity
    class Notification {
        - notificationId: String
        - userId: String
        - message: String
        - type: String
        - timestamp: DateTime
        - isRead: boolean
        
        + markAsRead(): void
        + getMessage(): String
    }
    
    ' ========================================================================
    ' SERVICES (Business Logic)
    ' ========================================================================
    
    class AccountService {
        - accountsRepository: AccountsRepository
        - passwordManager: PasswordManager
        
        + createAccount(account: Account): String
        + getAccount(accountId: String): Account
        + updateAccount(account: Account): void
        + deleteAccount(accountId: String): void
    }
    
    ' Refactored - Split BudgetService (Divergent Change)
    class BudgetCreationService {
        - budgetRepository: BudgetRepository
        
        + createBudget(plan: BudgetPlan): String
        + updateBudget(plan: BudgetPlan): void
        + deleteBudget(budgetId: String): void
    }
    
    class BudgetAnalyticsService {
        - budgetRepository: BudgetRepository
        - transactionRepository: TransactionRepository
        
        + analyzeSpending(budgetId: String): SpendingAnalysis
        + getTrends(budgetId: String, period: Period): List<Trend>
        + compareWithPrevious(budgetId: String): Comparison
    }
    
    class GoalService {
        - goalRepository: GoalRepository
        - notificationManager: NotificationManager
        
        + createGoal(goal: FinancialGoal): String
        + updateGoal(goal: FinancialGoal): void
        + trackProgress(goalId: String): Progress
        + contributeToGoal(goalId: String, amount: Money): void
    }
    
    class GroupSavingsService {
        - groupSavingsRepository: GroupSavingsRepository
        - notificationManager: NotificationManager
        
        + createGroup(group: GroupSavings): String
        + joinGroup(groupId: String, userId: String): void
        + contribute(groupId: String, userId: String, amount: Money): void
        + leaveGroup(groupId: String, userId: String): void
    }
    
    class PaymentsServiceBL {
        - paymentRepository: PaymentRepository
        - paymentCreator: PaymentCreator
        - gatewayAdapters: Map<String, PaymentGatewayAdapter>
        - notificationManager: NotificationManager
        
        + processPayment(payment: Payment): Response
        + scheduleRecurringPayment(payment: Payment, schedule: Schedule): String
        + cancelPayment(paymentId: String): void
        + refundPayment(paymentId: String): Response
    }
    
    class ReportingService {
        - reportBuilder: ReportBuilder
        - transactionRepository: TransactionRepository
        - budgetRepository: BudgetRepository
        
        + generateReport(filter: ReportFilter, type: String): Report
        + exportToPDF(report: Report): byte[]
        + scheduleReport(filter: ReportFilter, schedule: Schedule): String
    }
    
    class NotificationsServiceBL {
        - notificationRepository: NotificationRepository
        - notificationManager: NotificationManager
        
        + sendNotification(notification: Notification): void
        + getNotifications(userId: String): List<Notification>
        + markAsRead(notificationId: String): void
    }
    
    ' Extracted PasswordManager (Shotgun Surgery refactoring)
    class PasswordManager {
        - passwordHasher: PasswordHasher
        - passwordPolicy: PasswordPolicy
        
        + hashPassword(password: String): String
        + verifyPassword(password: String, hash: String): boolean
        + validateStrength(password: String): ValidationResult
        + changePassword(userId: String, oldPassword: String, newPassword: String): boolean
        + resetPassword(userId: String, token: String, newPassword: String): boolean
    }
    
    ' Service relationships
    AccountService --> AccountsRepository
    AccountService --> PasswordManager
    BudgetCreationService --> BudgetRepository
    BudgetAnalyticsService --> BudgetRepository
    BudgetAnalyticsService --> TransactionRepository
    GoalService --> GoalRepository
    GoalService --> NotificationManager
    GroupSavingsService --> GroupSavingsRepository
    GroupSavingsService --> NotificationManager
    PaymentsServiceBL --> PaymentRepository
    PaymentsServiceBL --> PaymentCreator
    PaymentsServiceBL --> PaymentGatewayAdapter
    PaymentsServiceBL --> NotificationManager
    ReportingService --> ReportBuilder
    ReportingService --> TransactionRepository
    ReportingService --> BudgetRepository
    NotificationsServiceBL --> NotificationRepository
    NotificationsServiceBL --> NotificationManager
}

' ============================================================================
' DATA ACCESS LAYER
' ============================================================================

package "Data Access Layer" as DataLayer {
    
    ' Repository Interfaces
    interface IRepository<T> {
        + save(entity: T): String
        + findById(id: String): T
        + update(entity: T): void
        + delete(id: String): void
        + findAll(): List<T>
    }
    
    interface AccountsRepository {
        + save(account: Account): String
        + findById(accountId: String): Account
        + findByUserId(userId: String): List<Account>
        + update(account: Account): void
        + delete(accountId: String): void
    }
    
    interface UserRepository {
        + save(user: UserAccount): String
        + findById(userId: String): UserAccount
        + findByUsername(username: String): UserAccount
        + findByEmail(email: String): UserAccount
        + update(user: UserAccount): void
        + delete(userId: String): void
    }
    
    interface TransactionRepository {
        + save(transaction: Transaction): String
        + findById(transactionId: String): Transaction
        + findByAccountId(accountId: String): List<Transaction>
        + findByDateRange(accountId: String, start: DateTime, end: DateTime): List<Transaction>
        + findByFilter(filter: ReportFilter): List<Transaction>
        + update(transaction: Transaction): void
        + delete(transactionId: String): void
    }
    
    interface BudgetRepository {
        + save(budget: BudgetPlan): String
        + findById(budgetId: String): BudgetPlan
        + findByUserId(userId: String): List<BudgetPlan>
        + findActive(userId: String): BudgetPlan
        + update(budget: BudgetPlan): void
        + delete(budgetId: String): void
    }
    
    interface GoalRepository {
        + save(goal: FinancialGoal): String
        + findById(goalId: String): FinancialGoal
        + findByUserId(userId: String): List<FinancialGoal>
        + findActiveGoals(userId: String): List<FinancialGoal>
        + update(goal: FinancialGoal): void
        + delete(goalId: String): void
    }
    
    interface PaymentRepository {
        + save(payment: Payment): String
        + findById(paymentId: String): Payment
        + findByAccountId(accountId: String): List<Payment>
        + findPending(): List<Payment>
        + update(payment: Payment): void
        + delete(paymentId: String): void
    }
    
    interface GroupSavingsRepository {
        + save(group: GroupSavings): String
        + findById(groupId: String): GroupSavings
        + findByMember(userId: String): List<GroupSavings>
        + update(group: GroupSavings): void
        + delete(groupId: String): void
    }
    
    interface NotificationRepository {
        + save(notification: Notification): String
        + findById(notificationId: String): Notification
        + findByUserId(userId: String): List<Notification>
        + findUnread(userId: String): List<Notification>
        + update(notification: Notification): void
        + delete(notificationId: String): void
    }
    
    ' Database Connection Pool (Optional Singleton)
    class DatabaseConnectionPool {
        - {static} instance: DatabaseConnectionPool
        - connections: Queue<Connection>
        - maxConnections: int
        
        - DatabaseConnectionPool()
        + {static} getInstance(): DatabaseConnectionPool
        + getConnection(): Connection
        + releaseConnection(conn: Connection): void
    }
}

' ============================================================================
' CROSS-CUTTING CONCERNS
' ============================================================================

package "Cross-Cutting Concerns" as CrossCutting {
    
    class SessionManager {
        - activeSessions: Map<String, Session>
        
        + createSession(userId: String): String
        + validateSession(sessionId: String): boolean
        + invalidateSession(sessionId: String): void
        + getSession(sessionId: String): Session
    }
    
    class PasswordHasher {
        + hash(password: String, salt: String): String
        + verify(password: String, hash: String): boolean
        + generateSalt(): String
    }
    
    class PasswordPolicy {
        - minLength: int
        - requireUppercase: boolean
        - requireLowercase: boolean
        - requireDigits: boolean
        - requireSpecialChars: boolean
        
        + validate(password: String): ValidationResult
    }
    
    class ValidationRequest {
        - data: Map<String, Object>
        
        + getData(key: String): Object
        + setData(key: String, value: Object): void
    }
    
    class ValidationResult {
        - valid: boolean
        - errors: List<String>
        
        + isValid(): boolean
        + getErrors(): List<String>
        + addError(error: String): void
    }
    
    class Event {
        - eventType: String
        - data: Object
        - timestamp: DateTime
        
        + getType(): String
        + getData(): Object
    }
    
    class NotificationEvent {
        - userId: String
        - message: String
        - priority: String
        
        + getUserId(): String
        + getMessage(): String
    }
    
    Event <|-- NotificationEvent
    
    PasswordManager --> PasswordHasher
    PasswordManager --> PasswordPolicy
}

