              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{supabase_url}}/rest/v1/budgets?user_id=eq.{{user_id}}&select=*",
              "host": ["{{supabase_url}}"],
              "path": ["rest", "v1", "budgets"],
              "query": [
                {
                  "key": "user_id",
                  "value": "eq.{{user_id}}"
                },
                {
                  "key": "select",
                  "value": "*"
                }
              ]
            }
          }
        },
